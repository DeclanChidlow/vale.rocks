[
	...post_data.ori
	...photography_data.ori
	...(demo_data.yaml → (_) => Tree.map(_, (demo) => {
		...demo
		type: "demo"
	}))
	...(sign-up_data.yaml → (_) => Tree.map(_, (sign-up) => {
		...sign-up
		type: "sign-up"
	}))
	...event_data.yaml → functions/expand-events.js
	...video_data.ori
	...pulse_data.ori
	...micro_data.ori
	...(elsewhere_data.yaml → (_) => Tree.map(_, (elsewhere) => {
		...elsewhere
		type: "elsewhere"
	}))
]
→ (_) => Tree.sort(_, (item) => item.pub_time)
→ Tree.reverse
